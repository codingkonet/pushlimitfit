# Cloud sync (optional). Without these the app runs fully offline as a guest.
# Get them from your Supabase project: Settings → API.
# The anon key is safe to expose in the client (Row Level Security protects data).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# PayPal checkout (optional). Enables real Pro purchases. The CLIENT ID is
# public (safe in the browser). The SECRET lives only in the Supabase Edge
# Function (see supabase/functions/paypal), never here.
# Without a client id, the Upgrade page falls back to a free demo unlock.
VITE_PAYPAL_CLIENT_ID=your-paypal-rest-client-id
VITE_PRO_CURRENCY=USD
