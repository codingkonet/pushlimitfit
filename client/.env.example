# Cloud sync (optional). Without these the app runs fully offline as a guest.
# Get them from your Supabase project: Settings → API.
# The anon key is safe to expose in the client (Row Level Security protects data).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
